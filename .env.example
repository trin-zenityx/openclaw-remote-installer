# === OpenClaw Remote Installer ===

# รหัสผ่านสำหรับเข้า Dashboard (เปลี่ยนเป็นรหัสของคุณ)
DASHBOARD_PASSWORD=teacher123

# API Key สำหรับ AI ช่วยติดตั้ง (สมัครได้ที่ console.anthropic.com)
ANTHROPIC_API_KEY=

# Port (Railway จะ set ให้อัตโนมัติ)
PORT=3000

# Tunnel (ใช้เฉพาะรันบนเครื่องตัวเอง ไม่ต้องใส่ถ้าใช้ Railway)
# TUNNEL_PROVIDER=localtunnel
# NGROK_AUTHTOKEN=

# AI Model
# AI_MODEL=claude-sonnet-4-5-20250929
